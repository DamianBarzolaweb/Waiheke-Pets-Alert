# Copiar a .env y ajustar
SECRET_KEY=genera-una-clave-larga-aleatoria
JWT_SECRET_KEY=otra-clave-para-jwt
DATABASE_URL=sqlite:///waiheke_pets.db
FLASK_ENV=development

# Producción (Heroku): URL pública del sitio (con www si el DNS está en www). Previews WhatsApp/OG y fotos locales.
# WPA_PUBLIC_BASE_URL=https://www.waihekepetsalert.co.nz
# Preview al compartir solo la home (no la última alerta):
# WPA_OG_HOME_TITLE=Waiheke Pets Alert
# WPA_OG_HOME_DESCRIPTION=Helping families reunite with lost pets on Waiheke Island.
# WPA_OG_HOME_IMAGE_URL=https://…/og-portal.jpg

# Orígenes extra CORS (HTTPS), separados por coma:
# CORS_ORIGINS=https://tu-app.netlify.app,https://www.tudominio.nz

# Registro: por defecto sólo verificación por email (OTP al correo). Phone/Twilio opcional.
# Poné 0 para volver al flujo Latino (Twilio Verify SMS/WhatsApp después de register/start).
# REGISTRATION_EMAIL_ONLY=0

# Omitir paso WhatsApp/Twilio: ...
# En producción (Heroku) solo si también ponés ALLOW_SKIP_PHONE_OTP_IN_PRODUCTION=1 (solo demos; inseguro).
# SKIP_WHATSAPP_OTP=1
# ALLOW_SKIP_PHONE_OTP_IN_PRODUCTION=1

# Registro estilo Waiheke Latinos (mismas variables que en el otro proyecto)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=VA30fa20e7dda482f2ad39d3cd547cef53
# Canal del mismo Verify Service: sms (rápido en trial sin Meta WABA) o whatsapp (ver docs Twilio)
TWILIO_VERIFY_CHANNEL=sms

# Sin Twilio: el registro usa un OTP ficticio (terminal + código en pantalla si FLASK_ENV=development).
# Forzar simulación aunque existan variables Twilio:
# DEV_SIMULATE_TWILIO=1

# Si no usás FLASK_ENV=development y querés igual mostrar OTP en JSON / link wa.me para probar en prod-staging mal configurado:
# DEV_EXPOSE_REGISTRATION_OTP=1

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Región Mailgun EU (opcional): eu
# MAILGUN_REGION=eu
# Remitente completo (opcional); default noreply@MAILGUN_DOMAIN
# MAILGUN_FROM=Waiheke Pets Alert <noreply@mg.example.nz>

# Al arrancar, borrar pet_alerts (opcional): ids exactos o nombres de mascota.
# Ej. un solo deploy con PRUNE_ALERT_NAMES=Mango y luego quitar variable en Heroku.
# PRUNE_ALERT_IDS=cooper,midnight
# PRUNE_ALERT_NAMES=Mango

# Fotos de reportes: Cloudinary en producción (Heroku sin esto = disco efímero).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=wpa-alerts
# WPA_MAX_PHOTO_BYTES=8388608

# Usuarios con admin total en el panel /api/admin (coma). Por defecto: damo
# WPA_SUPERADMIN_USERNAMES=damo

# Opcional: usuario de prueba local
# DEV_USERNAME=admin
# DEV_PASSWORD=tu_clave
